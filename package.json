{
  "name": "scoobie",
  "version": "21.2.0",
  "description": "Component library for SEEK documentation sites",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seek-oss/scoobie.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "require": "./lib/index.cjs",
      "import": "./lib/index.mjs"
    },
    "./typography": {
      "require": "./lib/typography.cjs",
      "import": "./lib/typography.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib"
  ],
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.cts",
  "scripts": {
    "format": "sku format",
    "lint": "sku lint",
    "loki:test": "loki test --port 12228 --host host.docker.internal --dockerNet host",
    "loki:test:ci": "cp -R dist-storybook/. dist-storybook-tmp/ && loki --requireReference --reactUri file:./dist-storybook-tmp --chromeFlags='--headless --hide-scrollbars --no-sandbox'",
    "loki:update": "loki update --port 12228",
    "build": "node ./prism.mjs && tsdown",
    "release": "changeset publish",
    "stage": "changeset version && pnpm format",
    "storybook:build": "storybook build --output-dir dist-storybook",
    "storybook:start": "storybook dev --port 12228",
    "test": "sku test",
    "test:ci": "sku test --coverage"
  },
  "dependencies": {
    "@capsizecss/core": "^4.0.0",
    "@vanilla-extract/css": "^1.2.3",
    "@vanilla-extract/css-utils": "^0.1.1",
    "clsx": "^2.0.0",
    "jsonc-parser": "^3.0.0",
    "polished": "^4.1.3",
    "prism-react-renderer": "^2.4.1"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.1",
    "@changesets/cli": "2.30.0",
    "@changesets/get-github-info": "0.8.0",
    "@loki/create-async-callback": "0.35.1",
    "@loki/is-loki-running": "0.35.0",
    "@storybook/addon-webpack5-compiler-babel": "4.0.1",
    "@storybook/react": "10.3.3",
    "@storybook/react-webpack5": "10.3.3",
    "@types/jest": "30.0.0",
    "@types/prismjs": "1.26.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "braid-design-system": "34.0.4",
    "eslint-plugin-storybook": "10.3.3",
    "loki": "0.35.1",
    "prismjs": "1.30.0",
    "publint": "0.3.17",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.13.2",
    "sku": "15.12.2",
    "storybook": "10.3.3",
    "tsdown": "0.21.7",
    "webpack": "5.105.4"
  },
  "peerDependencies": {
    "braid-design-system": ">= 31.21.0",
    "react": ">= 17 < 19",
    "react-router": ">= 7.5.2 < 8"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=18.18"
  },
  "pnpm": {
    "patchedDependencies": {
      "@loki/browser": "patches/@loki__browser.patch"
    }
  },
  "loki": {
    "configurations": {
      "chrome.laptop": {
        "target": "chrome.docker",
        "width": 1366,
        "height": 768,
        "mobile": false
      }
    },
    "chromeLoadTimeout": "60000",
    "chromeTolerance": "0"
  }
}
