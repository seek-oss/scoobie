{
  "name": "scoobie",
  "version": "22.0.0",
  "description": "Component library for SEEK documentation sites",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seek-oss/scoobie.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "require": "./lib/index.cjs",
      "import": "./lib/index.js"
    },
    "./typography": {
      "require": "./lib/typography.cjs",
      "import": "./lib/typography.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.cts",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "node ./prism.mjs && tsdown",
    "format": "sku format",
    "postinstall": "node ./prism.mjs",
    "lint": "sku lint",
    "loki:test": "loki test --port 12228 --host host.docker.internal --dockerNet host",
    "loki:test:ci": "cp -R dist-storybook/. dist-storybook-tmp/ && loki --requireReference --reactUri file:./dist-storybook-tmp --chromeFlags='--headless --hide-scrollbars --no-sandbox'",
    "loki:update": "loki update --port 12228",
    "prepack": "jq 'del(.scripts.postinstall)' package.json > package.json.tmp && mv package.json.tmp package.json",
    "release": "changeset publish",
    "stage": "changeset version && pnpm format",
    "storybook:build": "storybook build --output-dir dist-storybook",
    "storybook:start": "storybook dev --port 12228",
    "test": "sku test",
    "test:ci": "sku test --coverage"
  },
  "dependencies": {
    "@capsizecss/core": "^4.0.0",
    "@vanilla-extract/css": "^1.2.3",
    "@vanilla-extract/css-utils": "^0.1.1",
    "clsx": "^2.0.0",
    "jsonc-parser": "^3.0.0",
    "polished": "^4.1.3",
    "prism-react-renderer": "^2.4.1"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.2",
    "@changesets/cli": "2.31.0",
    "@changesets/get-github-info": "0.8.0",
    "@loki/create-async-callback": "0.35.1",
    "@loki/is-loki-running": "0.35.0",
    "@skuba-lib/changesets-changelog": "1.0.1",
    "@storybook/addon-webpack5-compiler-babel": "4.0.1",
    "@storybook/react": "10.4.1",
    "@storybook/react-webpack5": "10.4.1",
    "@types/jest": "30.0.0",
    "@types/prismjs": "1.26.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vanilla-extract/rollup-plugin": "1.5.3",
    "braid-design-system": "34.2.0",
    "eslint-plugin-storybook": "10.4.1",
    "loki": "0.35.1",
    "prismjs": "1.30.0",
    "publint": "0.3.21",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.1",
    "sku": "15.15.2",
    "storybook": "10.4.1",
    "tsdown": "0.22.0",
    "webpack": "5.107.2"
  },
  "peerDependencies": {
    "braid-design-system": ">= 31.21.0",
    "react": ">= 17 < 20",
    "react-router": ">= 7.5.2 < 8"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "engines": {
    "node": ">=22.18.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "@loki/browser": "patches/@loki__browser.patch"
    }
  },
  "loki": {
    "configurations": {
      "chrome.laptop": {
        "target": "chrome.docker",
        "width": 1366,
        "height": 768,
        "mobile": false
      }
    },
    "chromeLoadTimeout": "60000",
    "chromeTolerance": "0"
  }
}
